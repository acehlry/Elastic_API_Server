{
    "name": "metrics-api",
    "version": "1.0.0",
    "description": "Elasticsearch Metrics API Server",
    "main": "dist/server.js",
    "scripts": {
        "build": "tsc && cp -r src/queries dist/",
        "start": "node dist/server.js",
        "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
        "watch": "tsc -w",
        "test": "jest"
    },
    "dependencies": {
        "@elastic/elasticsearch": "^8.11.0",
        "@types/nodemailer": "^8.0.1",
        "compression": "^1.7.4",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "helmet": "^7.1.0",
        "joi": "^17.11.0",
        "mysql2": "^3.22.5",
        "nodemailer": "^8.0.11",
        "oracledb": "^7.0.0",
        "swagger-jsdoc": "^6.3.0",
        "swagger-ui-express": "^5.0.1",
        "winston": "^3.11.0"
    },
    "devDependencies": {
        "@types/compression": "^1.7.5",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jest": "^29.5.11",
        "@types/joi": "^17.2.3",
        "@types/node": "^20.10.5",
        "@types/oracledb": "^7.0.1",
        "@types/swagger-jsdoc": "^6.0.4",
        "@types/swagger-ui-express": "^4.1.8",
        "jest": "^29.7.0",
        "ts-jest": "^29.1.1",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.3.3"
    },
    "engines": {
        "node": ">=18.0.0"
    }
