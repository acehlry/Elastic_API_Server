{
  "size": 0,
  "query": {
    "bool": {
      "must": [],
      "filter": [
        {
          "terms": {
            "metricset.name": ["cpu", "memory", "filesystem", "network"]
          }
        }
      ]
    }
  },
  "aggs": {
    "by_host": {
      "terms": {
        "field": "host.name",
        "size": 1000
      },
      "aggs": {
        "last_seen": {
          "max": { "field": "@timestamp" }
        },
        "by_metricset": {
          "terms": {
            "field": "metricset.name",
            "include": ["cpu", "memory", "filesystem", "network"]
          },
          "aggs": {
            "latest": {
              "top_hits": {
                "size": 1,
                "sort": [{ "@timestamp": { "order": "desc" } }],
                "_source": {
                  "includes": [
                    "@timestamp",
                    "host.name",
                    "host.ip",
                    "host.os.name",
                    "host.os.version",
                    "system.cpu.total.norm.pct",
                    "system.memory.used.pct",
                    "system.filesystem.used.pct",
                    "system.load.1",
                    "system.load.5",
                    "system.load.15"
                  ]
                }
              }
            },
            "network_in_max":  { "max": { "field": "system.network.in.bytes" } },
            "network_in_min":  { "min": { "field": "system.network.in.bytes" } },
            "network_out_max": { "max": { "field": "system.network.out.bytes" } },
            "network_out_min": { "min": { "field": "system.network.out.bytes" } }
          }
        }
      }
    }
  }
}
