{
  "size": 0,
  "query": {
    "bool": {
      "must": []
    }
  },
  "aggs": {
    "by_host": {
      "terms": {
        "field": "host.name",
        "size": 1000
      },
      "aggs": {
        "latest": {
          "top_hits": {
            "size": 1,
            "sort": [{ "@timestamp": { "order": "desc" } }],
            "_source": {
              "includes": [
                "@timestamp",
                "host.name",
                "host.ip",
                "system.filesystem.used.pct"
              ]
            }
          }
        }
      }
    }
  }
}
